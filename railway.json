{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "env": {
    "DEEPSEEK_API_KEY": {
      "fromSecret": "DEEPSEEK_API_KEY"
    },
    "DATABASE_PATH": {
      "default": "astock.db"
    },
    "PYTHONPATH": {
      "default": "/app"
    }
  }
}
