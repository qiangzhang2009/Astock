{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPkgs": ["python3", "python3Packages.pip", "git"]
  },
  "deploy": {
    "numReplicas": 1,
    "sleep": "false",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": "PYTHON",
    "command": "uvicorn backend.api.main:app --host 0.0.0.0 --port $PORT"
  },
  "upstream": {
    "id": "astock-backend"
  },
  "environment": {
    "DEEPSEEK_API_KEY": {
      "fromSecret": "DEEPSEEK_API_KEY"
    }
  }
}
